# SQLite (Entwicklung). Für PostgreSQL: provider in prisma/schema.prisma auf "postgresql"
# stellen und DATABASE_URL anpassen, z. B. postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"
AUTH_SECRET="bitte-durch-zufallswert-ersetzen"
APP_URL="http://localhost:3000"
# MAIL_PROVIDER: "log" (Entwicklung) | "smtp"
MAIL_PROVIDER="log"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="noreply@example.com"
CRON_SECRET="bitte-zufallswert-setzen"
