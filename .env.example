# SQLite (Entwicklung). Für PostgreSQL: provider in prisma/schema.prisma auf "postgresql"
# stellen und DATABASE_URL anpassen, z. B. postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"
AUTH_SECRET="bitte-durch-zufallswert-ersetzen"
APP_URL="http://localhost:3000"
# MAIL_PROVIDER: "log" (Entwicklung) | "smtp" (Produktion, implementiert via nodemailer)
# SMTP-Zugangsdaten kommen vom Mail-Hoster der Domain ki-nachweis.at.
# Port 587 = STARTTLS (Standard) | 465 = implizites TLS.
# Zustellbarkeit: SPF- und DKIM-DNS-Einträge für ki-nachweis.at setzen!
MAIL_PROVIDER="log"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER="info@ki-nachweis.at"
SMTP_PASS=""
MAIL_FROM="KI-Kompetenz Campus <noreply@ki-nachweis.at>"
# Antworten auf Systemmails landen hier (optional, empfohlen):
MAIL_REPLY_TO="info@ki-nachweis.at"
CRON_SECRET="bitte-zufallswert-setzen"
